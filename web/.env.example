# Web3Forms access key for the contact form (https://web3forms.com — free, enter your email to get one).
# Copy this file to `.env` and paste your key. Without it, the form shows a "not configured" message.
PUBLIC_WEB3FORMS_KEY=

# Privacy-friendly, cookieless analytics (optional — leave all blank to disable).
# No cookies, no personal data — GDPR/LGPD-friendly. For Cloud Run these are baked
# into the static build, so pass them as Docker --build-arg / GitHub secrets.
#
# Plausible (Cloud or self-hosted): set the domain you registered.
#   PUBLIC_ANALYTICS_DOMAIN=bessavagner.com
#   PUBLIC_ANALYTICS_SRC=          # optional; defaults to https://plausible.io/js/script.js
#
# Umami (Cloud or self-hosted): set the website id + script URL.
#   PUBLIC_ANALYTICS_WEBSITE_ID=00000000-0000-0000-0000-000000000000
#   PUBLIC_ANALYTICS_SRC=https://cloud.umami.is/script.js
PUBLIC_ANALYTICS_DOMAIN=
PUBLIC_ANALYTICS_WEBSITE_ID=
PUBLIC_ANALYTICS_SRC=

# Google Search Console verification (optional). Paste the token from the
# "HTML tag" method (the content="..." value). Or verify via DNS TXT (no code).
PUBLIC_GSC_VERIFICATION=
