# Web3Forms access key for the contact form (https://web3forms.com — free, enter your email to get one).
# Copy this file to `.env` and paste your key. Without it, the form shows a "not configured" message.
PUBLIC_WEB3FORMS_KEY=

# Privacy-friendly, cookieless analytics (optional — leave blank to disable entirely).
# Plausible Cloud: set the domain you registered there, e.g. bessavagner.com
# Self-hosted Plausible / Umami: also set PUBLIC_ANALYTICS_SRC to your script URL.
# No cookies, no personal data — GDPR/LGPD-friendly. For Cloud Run, pass as a
# --build-arg / Docker ARG (it is baked into the static output, like the Web3Forms key).
PUBLIC_ANALYTICS_DOMAIN=
PUBLIC_ANALYTICS_SRC=
