{
  "name": "bessavagner-web",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "astro": "astro",
    "search:verify": "astro build && node scripts/assert-pagefind-index.mjs",
    "utm": "node --experimental-strip-types scripts/utm/build-url.ts",
    "utm:audit": "node scripts/utm/assert-no-internal-utm.mjs",
    "diagram:build": "node scripts/diagrams/render.mjs",
    "post:approve": "node --experimental-strip-types scripts/post.ts approve",
    "post:status": "node --experimental-strip-types scripts/post.ts status",
    "post:gate": "node --experimental-strip-types scripts/post.ts gate",
    "post:lint": "node --experimental-strip-types scripts/post.ts lint",
    "post:preview": "node --experimental-strip-types scripts/post.ts preview"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^7.0.0",
    "astro-pagefind": "^2.0.1",
    "pagefind": "^1.5.2",
    "satori": "^0.26.0",
    "sharp": "^0.35.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.1.0",
    "daisyui": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@10.15.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
