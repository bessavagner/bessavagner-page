digraph regwatch_sameorigin {
  rankdir=TB;
  bgcolor="#0e121b";
  pad=0.35; nodesep=0.40; ranksep=0.55;
  fontname="Helvetica,Arial,sans-serif"; fontcolor="#e6e8eb"; fontsize=15;
  labelloc="t";
  label=<<b>RegWatch &#8212; one origin, two kinds of response</b><br/><font point-size="10.5" color="#9aa3b2">the SPA and the API answer on the same host, so the session cookie is first-party and there is no CORS</font><br/> >;

  node [shape=box, style="rounded,filled", fontname="Helvetica,Arial,sans-serif", fontsize=11,
        fillcolor="#1b2230", color="#60a5fa", fontcolor="#e7eefc", penwidth=1.5, margin="0.20,0.12"];
  edge [color="#8b93a7", penwidth=1.3, arrowsize=0.8,
        fontname="Helvetica,Arial,sans-serif", fontsize=9, fontcolor="#9aa3b2"];

  // external client
  browser [label="Browser · Svelte 5 SPA\nsends session cookie + X-CSRFToken",
           color="#d8a657", fontcolor="#f4e8cf", fillcolor="#231c10", penwidth=1.7];

  // the one service that answers both
  subgraph cluster_svc {
    label=<<font color="#c9cace"><b>One origin &#183; one Cloud Run Service (gunicorn)</b></font>>;
    labeljust="l"; color="#3a4660"; style="rounded"; penwidth=1.5; fontsize=12; margin=18;

    urls [label="Django URLconf\nmatches top to bottom", fillcolor="#16233a"];
    api  [label="/api/*  →  DRF\nsession auth · workspace-scoped views", fillcolor="#122033"];
    spa  [label="(?!api/)  →  WhiteNoise\nindex.html + /assets/*", fillcolor="#122033"];
  }

  db [label="Postgres (Supabase)", shape=cylinder, fillcolor="#16203a", color="#3a4a63", fontcolor="#cfe0f5"];

  browser -> urls [label="every request\n(cookie + CSRF, same-origin)"];
  urls -> api  [label="path starts with api/"];
  urls -> spa  [label="everything else (SPA fallback)"];
  api  -> db   [label="scoped queries"];
}
