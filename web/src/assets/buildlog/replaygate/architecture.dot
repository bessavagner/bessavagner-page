digraph replaygate {
  rankdir=TB;
  bgcolor="#0e121b";
  pad=0.35; nodesep=0.36; ranksep=0.5;
  fontname="Helvetica,Arial,sans-serif"; fontcolor="#e6e8eb"; fontsize=15;
  labelloc="t";
  label=<<b>ReplayGate &#8212; what the harness does</b><br/><font point-size="10.5" color="#9aa3b2">green = ReplayGate, shipped in v0&#160;&#160;&#183;&#160;&#160;dashed grey = ReplayGate, roadmap&#160;&#160;&#183;&#160;&#160;amber = the agent under test (external)</font><br/> >;

  node [shape=box, style="rounded,filled", fontname="Helvetica,Arial,sans-serif", fontsize=11,
        fillcolor="#1b2230", color="#34d399", fontcolor="#e7f6ef", penwidth=1.5, margin="0.20,0.12"];
  edge [color="#8b93a7", penwidth=1.3, arrowsize=0.8,
        fontname="Helvetica,Arial,sans-serif", fontsize=9, fontcolor="#9aa3b2"];

  // ---- external: the system under test (NOT part of ReplayGate) ----
  agent [label="Agent under test\nyour LLM agent — not part of ReplayGate\n(ships a BookingAgent example to demo against)",
         color="#d8a657", fontcolor="#f4e8cf", fillcolor="#231c10", style="rounded,filled,dashed", penwidth=1.7];

  // ---- the harness we build ----
  subgraph cluster_rg {
    label=<<font color="#c9cace"><b>ReplayGate &#183; the harness</b></font>>;
    labeljust="l"; color="#3a4660"; style="rounded"; penwidth=1.5; fontsize=12; margin=18;

    cli     [label="CLI: replaygate record", fillcolor="#16241c"];
    adapter [label="Channel adapter\nfeeds user turns in (per channel)\ndirect (shipped) · WhatsApp (roadmap)"];
    rec     [label="RecordingLLMClient\nwraps the agent's LLM client"];
    tools   [label="ToolRecorder\nwraps the agent's tools"];
    fix     [label="Fixture directory\nconversation · llm · tool · spans · meta", shape=folder, fillcolor="#16203a", color="#3a4a63"];
    store   [label="DuckDB span store\nOTel gen_ai.* conventions"];

    node [color="#64748b", fontcolor="#aab2c0", fillcolor="#141a24", style="rounded,filled,dashed"];
    replay [label="Replayer\nreplay vs new model / prompt\ntools mocked"];
    diff   [label="ConversationDiff\nbaseline vs current path"];
    inv    [label="Cross-turn invariants\nuser_confirmed_before(...)\n\"never books before confirm\""];
    gate   [label="replaygate regress\nCI gate — pass / fail"];
  }

  // ---- shipped record flow (solid) ----
  cli     -> adapter [label="invokes"];
  adapter -> agent   [label="user turns"];
  agent   -> rec     [label="LLM calls", color="#d8a657", fontcolor="#caa86a"];
  agent   -> tools   [label="tool calls", color="#d8a657", fontcolor="#caa86a"];
  rec     -> fix     [label="record"];
  tools   -> fix     [label="record"];

  // ---- deferred / roadmap (dashed) ----
  edge [style=dashed, color="#5b6472"];
  rec  -> store   [label="spans (wiring: next)"];
  fix  -> replay  [label="feed back"];
  replay -> diff;
  diff -> inv;
  inv  -> gate;
  store -> diff   [label="timing"];
}
