---
const links = [
  { href: '/#section-featured', label: 'Work' },
  { href: '/building/', label: 'Building' },
  { href: '/blog/', label: 'Blog' },
];
---
<!-- Drawer toggle: a peer checkbox drives the mobile menu purely in CSS;
     the inline script below layers on a11y state, Esc-to-close, scroll-lock. -->
<input id="nav-drawer" type="checkbox" class="peer sr-only" aria-hidden="true" tabindex="-1" />

<nav id="site-nav" class="site-nav navbar lg:h-32 w-full justify-end fixed top-0 right-0 left-0 lg:px-30 z-30 bg-transparent" aria-label="Main">
  <div class="flex-1">
    <a href="/" class="btn btn-ghost text-xl roboto-condensed-800">Vagner Bessa</a>
  </div>
  <div class="flex items-center gap-3">
    {links.map((l) => (
      <a href={l.href} class="btn btn-ghost btn-sm font-base hidden sm:inline-flex">{l.label}</a>
    ))}
    <a href="/#section-contact" class="btn btn-primary btn-sm font-base">Contact</a>
    <label class="swap swap-rotate btn btn-ghost btn-square btn-sm" aria-label="Toggle dark mode" title="Toggle dark mode">
      <input type="checkbox" class="theme-controller" />
      <svg class="swap-off h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M5.64 17l-.71.71a1 1 0 0 0 1.41 1.41l.71-.71A1 1 0 0 0 5.64 17zM5 12a1 1 0 0 0-1-1H3a1 1 0 0 0 0 2h1a1 1 0 0 0 1-1zm7-7a1 1 0 0 0 1-1V3a1 1 0 0 0-2 0v1a1 1 0 0 0 1 1zM5.64 7.05a1 1 0 0 0 .7.29 1 1 0 0 0 .71-.29 1 1 0 0 0 0-1.41l-.71-.71a1 1 0 0 0-1.41 1.41zM17 5.64a1 1 0 0 0 .71-.29l.71-.71a1 1 0 1 0-1.41-1.41l-.71.71A1 1 0 0 0 17 5.64zM21 11h-1a1 1 0 0 0 0 2h1a1 1 0 0 0 0-2zm-9 8a1 1 0 0 0-1 1v1a1 1 0 0 0 2 0v-1a1 1 0 0 0-1-1zm6.36-2a1 1 0 0 0-1.41 1.41l.71.71a1 1 0 0 0 1.41-1.41zM12 6.5A5.5 5.5 0 1 0 17.5 12 5.51 5.51 0 0 0 12 6.5z"/></svg>
      <svg class="swap-on h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M21.64 13a1 1 0 0 0-1.05-.14 8.05 8.05 0 0 1-3.37.73 8.15 8.15 0 0 1-8.14-8.1 8.59 8.59 0 0 1 .25-2A1 1 0 0 0 8 2.36a10.14 10.14 0 1 0 14 11.69 1 1 0 0 0-.36-1.05z"/></svg>
    </label>
    <!-- Hamburger: mobile only -->
    <label for="nav-drawer" id="nav-drawer-open" class="btn btn-ghost btn-square btn-sm sm:hidden" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
      <svg class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6a1 1 0 0 1 1-1h16a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1zm0 6a1 1 0 0 1 1-1h16a1 1 0 1 1 0 2H4a1 1 0 0 1-1-1zm1 5a1 1 0 1 0 0 2h16a1 1 0 1 0 0-2H4z"/></svg>
    </label>
  </div>
</nav>

<!-- Backdrop -->
<label for="nav-drawer" aria-hidden="true"
  class="fixed inset-0 z-[55] bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 peer-checked:opacity-100 peer-checked:pointer-events-auto sm:hidden"></label>

<!-- Slide-in drawer -->
<aside id="mobile-menu"
  class="fixed top-0 right-0 z-[60] h-full w-72 max-w-[80%] translate-x-full bg-base-100 shadow-2xl transition-transform duration-300 ease-out peer-checked:translate-x-0 sm:hidden"
  aria-label="Mobile">
  <div class="flex items-center justify-between px-5 h-16 border-b border-base-300">
    <span class="roboto-condensed-800 text-lg">Menu</span>
    <label for="nav-drawer" class="btn btn-ghost btn-square btn-sm" aria-label="Close menu">
      <svg class="h-5 w-5 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M6.4 4.99 4.99 6.4 10.59 12l-5.6 5.6 1.41 1.41L12 13.41l5.6 5.6 1.41-1.41L13.41 12l5.6-5.6-1.41-1.41L12 10.59z"/></svg>
    </label>
  </div>
  <nav class="flex flex-col p-3" aria-label="Mobile primary">
    {links.map((l) => (
      <a href={l.href} data-nav-link class="font-base text-base-content/90 rounded-field px-4 py-3 hover:bg-base-200 active:bg-base-200">{l.label}</a>
    ))}
    <a href="/#section-contact" data-nav-link class="btn btn-primary font-base mt-3 mx-1">Contact</a>
  </nav>
</aside>

<style>
  /* Transparent over the hero; frosted + compact once the page scrolls. */
  .site-nav {
    border-bottom: 1px solid transparent;
    transition: background-color .3s ease, backdrop-filter .3s ease,
      height .3s ease, min-height .3s ease, box-shadow .3s ease, border-color .3s ease;
  }
  .site-nav.is-scrolled {
    height: 5rem;
    min-height: 5rem;
    background-color: color-mix(in oklab, var(--color-base-100) 80%, transparent);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border-bottom-color: color-mix(in oklab, var(--color-base-content) 12%, transparent);
    box-shadow: 0 6px 24px -12px rgba(0, 0, 0, .35);
  }
  @media (prefers-reduced-motion: reduce) {
    .site-nav { transition: none; }
  }
</style>

<script is:inline>
  (function () {
    var toggle = document.querySelector('.theme-controller');
    if (toggle) {
      var isDark = document.documentElement.getAttribute('data-theme') === 'custom-dark';
      toggle.checked = isDark;
      toggle.addEventListener('change', function () {
        var theme = toggle.checked ? 'custom-dark' : 'custom';
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
      });
    }

    var drawer = document.getElementById('nav-drawer');
    var opener = document.getElementById('nav-drawer-open');
    if (drawer) {
      var sync = function () {
        var open = drawer.checked;
        if (opener) opener.setAttribute('aria-expanded', open ? 'true' : 'false');
        document.body.style.overflow = open ? 'hidden' : '';
      };
      drawer.addEventListener('change', sync);
      // Close after tapping a link (same-page anchors don't navigate away).
      document.querySelectorAll('[data-nav-link]').forEach(function (a) {
        a.addEventListener('click', function () { drawer.checked = false; sync(); });
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && drawer.checked) { drawer.checked = false; sync(); }
      });
    }

    // Transparent at the top → frosted/compact once scrolled.
    var nav = document.getElementById('site-nav');
    if (nav) {
      var ticking = false;
      var onScroll = function () {
        ticking = false;
        nav.classList.toggle('is-scrolled', window.scrollY > 8);
      };
      onScroll();
      window.addEventListener('scroll', function () {
        if (!ticking) { ticking = true; requestAnimationFrame(onScroll); }
      }, { passive: true });
    }
  })();
</script>
