---
import type { BuildUpdate, BuildProject } from '../../lib/buildlog';
import { splitUpdateId } from '../../lib/buildlog';
import { readingTime } from '../../lib/blog';
import UpdateMeta from './UpdateMeta.astro';
interface Props { project: BuildProject; latest: BuildUpdate; count: number; }
const { project, latest, count } = Astro.props;
const hubHref = `/building/${project.slug}/`;
const { slug } = splitUpdateId(latest.id);
const latestHref = `/building/${project.slug}/${slug}/`;
const minutes = readingTime(latest.body ?? '');
---
<article class="group relative rounded-2xl border border-base-content/10 bg-base-200/40 p-6 hover:border-primary/40 transition-colors">
  <div class="flex items-center gap-2">
    <span class="badge badge-primary badge-sm font-base">Building</span>
    <span class="ubuntu-mono-regular text-xs text-base-content/55">{count} update{count === 1 ? '' : 's'}</span>
  </div>
  <h2 class="font-header text-2xl font-bold leading-tight mt-3">
    <a href={hubHref} class="after:absolute after:inset-0 group-hover:text-primary transition-colors">{project.title}</a>
  </h2>
  <p class="font-base text-sm text-base-content/70 mt-1">{project.tagline}</p>
  <p class="font-base text-sm text-base-content/75 mt-3 leading-relaxed line-clamp-2">{project.blurb}</p>
  <div class="mt-5 pt-4 border-t border-base-content/10">
    <p class="ubuntu-mono-regular text-xs uppercase tracking-widest text-accent mb-1">Latest</p>
    <a href={latestHref} class="relative z-10 font-base text-base font-semibold leading-snug hover:text-primary">{latest.data.title}</a>
    <UpdateMeta pubDate={latest.data.pubDate} minutes={minutes} update={latest.data.update} class="mt-2" />
  </div>
  <span class="relative z-10 inline-flex items-center gap-1 font-base text-sm text-primary mt-4">View build log →</span>
</article>
