---
import { formatDate } from '../../lib/blog';
interface Props { pubDate: Date; minutes: number; tags: string[]; class?: string; }
const { pubDate, minutes, tags, class: className = '' } = Astro.props;
---
<div class:list={["flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-base-content/60", className]}>
  <time datetime={pubDate.toISOString()} class="ubuntu-mono-regular">{formatDate(pubDate)}</time>
  <span aria-hidden="true">·</span>
  <span class="ubuntu-mono-regular">{minutes} min read</span>
  {tags.length > 0 && (
    <ul class="flex flex-wrap gap-2">
      {tags.map((t) => (
        <li><a href={`/blog/tags/${t}/`} class="badge badge-outline border-primary/40 font-base text-xs">#{t}</a></li>
      ))}
    </ul>
  )}
</div>
