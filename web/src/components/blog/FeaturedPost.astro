---
import type { Post } from '../../lib/blog';
import { readingTime } from '../../lib/blog';
import { Image } from 'astro:assets';
import PostMeta from './PostMeta.astro';
import CoverFallback from './CoverFallback.astro';
interface Props { post: Post; }
const { post } = Astro.props;
const minutes = readingTime(post.body ?? '');
const href = `/blog/${post.id}/`;
const cover = post.data.heroImage;
---
<article class="group relative grid gap-6 md:grid-cols-2 md:items-center">
  <div class="order-1 md:order-2 overflow-hidden rounded-xl border border-base-content/10 bg-base-200/40 aspect-[16/10]">
    {cover
      ? <Image src={cover} alt="" width={720} height={450} loading="eager" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" />
      : <CoverFallback title={post.data.title} />}
  </div>
  <div class="order-2 md:order-1 min-w-0">
    <PostMeta pubDate={post.data.pubDate} minutes={minutes} tags={post.data.tags} class="relative z-10" />
    <h2 class="font-header text-3xl md:text-4xl font-bold leading-tight mt-2">
      <a href={href} class="after:absolute after:inset-0 group-hover:text-primary transition-colors">{post.data.title}</a>
    </h2>
    <p class="font-base text-base text-base-content/75 mt-3 leading-relaxed max-w-[60ch]">{post.data.description}</p>
  </div>
</article>
