---
import { resolveCta, type CtaGoal, type Collection } from '../../lib/cta-core';
import { portfolio, asset } from '../../lib/portfolio';
import { EVENTS } from '../../lib/analytics-events';
interface Props { goal?: CtaGoal; collection: Collection; projectHub?: string; class?: string; }
const { goal, collection, projectHub, class: className = '' } = Astro.props;
const cta = resolveCta(goal, collection);
// Context overrides the resolver's static defaults where the destination is
// config- or page-specific: the CV asset, and the current project's hub.
let href = cta.href;
if (cta.goal === 'cv') href = asset(portfolio.profile.links.cv);
if (cta.goal === 'follow-build' && projectHub) href = projectHub;
const email = portfolio.profile.links.email;
const external = cta.goal === 'cv';
---
{href && (
  <section class:list={["mt-12 pt-8 border-t border-base-content/10", className]} aria-label="What next">
    <p class="font-base text-base-content/80 max-w-[60ch]">{cta.lead}</p>
    <div class="mt-4 flex flex-wrap items-center gap-4">
      <a href={href} {...(external ? { target: '_blank', rel: 'noopener' } : {})}
         data-track={EVENTS.CTA_CLICK} data-track-goal={cta.goal} data-track-location="post_end"
         class="btn btn-primary btn-sm font-base">{cta.action} →</a>
      {email && (
        <a href={`mailto:${email}`} data-track={EVENTS.EMAIL_CLICK} data-track-location="post_end"
           class="font-base text-sm text-base-content/60 hover:text-primary">or email me directly</a>
      )}
    </div>
  </section>
)}
