---
import type { Post } from '../../lib/blog';
import { readingTime } from '../../lib/blog';
import { Image } from 'astro:assets';
import PostMeta from './PostMeta.astro';
import CoverFallback from './CoverFallback.astro';
interface Props { post: Post; }
const { post } = Astro.props;
const minutes = readingTime(post.body ?? '');
const href = `/blog/${post.id}/`;
const cover = post.data.heroImage;
---
<article class="group relative grid grid-cols-[5rem_1fr] sm:grid-cols-[7rem_1fr] gap-4 sm:gap-5 py-6 transition-colors">
  <div class="overflow-hidden rounded-lg border border-base-content/10 bg-base-200/40 aspect-[16/10]">
    {cover
      ? <Image src={cover} alt="" width={224} height={140} loading="lazy" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]" />
      : <CoverFallback title={post.data.title} />}
  </div>
  <div class="min-w-0">
    <h2 class="font-header text-xl md:text-2xl font-semibold leading-snug">
      <a href={href} class="after:absolute after:inset-0 group-hover:text-primary transition-colors">{post.data.title}</a>
    </h2>
    <PostMeta pubDate={post.data.pubDate} minutes={minutes} tags={post.data.tags} class="relative z-10 mt-2" />
    <p class="font-base text-sm text-base-content/70 mt-2 leading-relaxed line-clamp-2 max-w-[65ch]">{post.data.description}</p>
  </div>
</article>
