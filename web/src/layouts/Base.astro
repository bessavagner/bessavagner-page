---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Vagner Bessa — Full-stack & AI Engineer',
  description = 'Full-stack and AI engineer building production-grade AI products and web platforms in Python and TypeScript. Available for international freelance projects and roles.',
  ogImage = '/images/og-default.png',
} = Astro.props;

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://bessavagner.com';
const canonical = new URL(Astro.url.pathname, Astro.site ?? siteUrl).href;
const ogImageUrl = new URL(ogImage, Astro.site ?? siteUrl).href;

// Privacy-friendly, cookieless analytics. No cookies, no PII. Inert until configured.
//   Plausible: set PUBLIC_ANALYTICS_DOMAIN=bessavagner.com (default src below;
//              override PUBLIC_ANALYTICS_SRC when self-hosting).
//   Umami:     set PUBLIC_ANALYTICS_WEBSITE_ID=<uuid> and PUBLIC_ANALYTICS_SRC to
//              your Umami script URL (e.g. https://cloud.umami.is/script.js).
const analyticsDomain = import.meta.env.PUBLIC_ANALYTICS_DOMAIN;
const analyticsWebsiteId = import.meta.env.PUBLIC_ANALYTICS_WEBSITE_ID;
const analyticsSrc = import.meta.env.PUBLIC_ANALYTICS_SRC ?? 'https://plausible.io/js/script.js';

const fontHref =
  'https://fonts.googleapis.com/css2?family=Ubuntu+Mono:wght@400;700&family=Roboto+Condensed:wght@800&family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,400&display=swap';
---
<!DOCTYPE html>
<html lang="en" data-theme="custom">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var prefersDark = window.matchMedia &&
          window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute(
          'data-theme', stored || (prefersDark ? 'custom-dark' : 'custom')
        );
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Vagner Bessa" />
    <meta name="theme-color" content="#3a3d98" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vagner Bessa" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Load fonts without blocking render (display=swap shows fallback first). */}
    <link rel="preload" as="style" href={fontHref} />
    <noscript><link rel="stylesheet" href={fontHref} /></noscript>
    <script is:inline define:vars={{ fontHref }}>
      (function () {
        var l = document.createElement('link');
        l.rel = 'stylesheet';
        l.href = fontHref;
        document.head.appendChild(l);
      })();
    </script>

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Vagner Bessa',
      url: siteUrl,
      jobTitle: 'Full-stack & AI Engineer',
      email: 'mailto:bessavagner.dev@gmail.com',
      sameAs: ['https://github.com/bessavagner', 'https://www.linkedin.com/in/bessavagner/'],
      knowsAbout: ['Python', 'TypeScript', 'Artificial Intelligence', 'LLM agents', 'Web development', 'Machine learning'],
    })} />

    {analyticsWebsiteId ? (
      <script is:inline defer src={analyticsSrc} data-website-id={analyticsWebsiteId}></script>
    ) : analyticsDomain && (
      <script is:inline defer data-domain={analyticsDomain} src={analyticsSrc}></script>
    )}
  </head>
  <body class="relative flex flex-col min-h-screen bg-base-100">
    <Header />
    <main id="content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
