---
import Base from '../../layouts/Base.astro';
import BuildProjectCard from '../../components/building/BuildProjectCard.astro';
import ShippedCard from '../../components/building/ShippedCard.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import { getIndexData } from '../../lib/buildlog';
import { jsonLd } from '../../lib/jsonld';

const { active, shipped } = await getIndexData();
const siteHref = (Astro.site?.href ?? 'https://bessavagner.com/').replace(/\/$/, '');
const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${siteHref}/building/#building`,
  name: 'Vagner Bessa — Building Publicly',
  description: 'Updates from projects I am building in public.',
  url: `${siteHref}/building/`,
  author: { '@id': `${siteHref}/#vagner-bessa` },
  inLanguage: 'en',
};
---
<Base title="Building Publicly — Vagner Bessa" description="Updates from the projects I am building in public, grouped by project." rssHref="/building/rss.xml" rssTitle="Vagner Bessa — Building Publicly" spotlightGrid>
  <script is:inline type="application/ld+json" set:html={jsonLd(pageSchema)} />
  <section class="w-11/12 max-w-4xl mx-auto pt-28 pb-20">
    <h1 class="font-header text-4xl md:text-5xl font-semibold">Building Publicly</h1>
    <p class="font-base text-lg text-base-content/70 mt-3">Progress updates from the projects I'm building in the open. Finished projects can be found under <a href="/#section-featured" class="text-primary hover:underline">Work</a>.</p>

    {active.length === 0 && shipped.length === 0 ? (
      <p class="font-base text-base-content/60 mt-10">No build logs yet — check back soon.</p>
    ) : (
      <div class="mt-12 space-y-16">
        {active.length > 0 && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {active.map(({ project, latest, count }) => <BuildProjectCard project={project} latest={latest} count={count} />)}
          </div>
        )}
        {shipped.length > 0 && (
          <div>
            <h2 class="font-header-5 font-bold">Shipped</h2>
            <p class="font-base text-sm text-base-content/60 mt-1">Finished builds. Each links to its case study and its full build log.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mt-6">
              {shipped.map(({ project, count }) => <ShippedCard project={project} count={count} />)}
            </div>
          </div>
        )}
      </div>
    )}
    <SubscribeForm class="mt-16" heading="Follow the build" />
  </section>
</Base>
