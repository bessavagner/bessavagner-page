---
import { Image } from 'astro:assets';
import avatar from '../assets/avatar.png';
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import TechStack from '../components/TechStack.astro';
import ProjectSection from '../components/ProjectSection.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Contact from '../components/Contact.astro';
import { portfolio, updated } from '../lib/portfolio';
import { jsonLd } from '../lib/jsonld';
import { profilePageNode, projectItemList } from '../lib/schema';

const { profile, featured, cards } = portfolio;
const siteUrl = (Astro.site?.href ?? 'https://bessavagner.com/').replace(/\/$/, '');
const allProjects = [...featured, ...cards];
---
<Base>
  <script is:inline type="application/ld+json" set:html={jsonLd({
    '@context': 'https://schema.org',
    ...profilePageNode(siteUrl, updated),
  })} />
  <script is:inline type="application/ld+json" set:html={jsonLd({
    '@context': 'https://schema.org',
    ...projectItemList(siteUrl, allProjects),
  })} />
  <Hero profile={profile} />

  <!-- About / Stack -->
  <section id="section-about" class="w-full px-6 py-16 lg:py-24 bg-base-200/40">
    <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-14 w-11/12 max-w-5xl mx-auto">
      <div class="flex flex-col items-center text-center lg:w-1/3 shrink-0">
        <div class="avatar">
          <div class="w-40 h-40 rounded-full ring ring-primary/30 ring-offset-base-100 ring-offset-2">
            <Image src={avatar} alt="Portrait of Vagner Bessa" width={320} height={320} loading="lazy" />
          </div>
        </div>
        <p class="font-base roboto-light text-base lg:text-lg mt-5 text-base-content/80">
          I build smart, fast solutions end to end — from AI agents and APIs to the interfaces people use.
        </p>
        {profile.location && <p class="ubuntu-mono-regular text-xs text-base-content/70 mt-3">{profile.location}</p>}
      </div>
      <div class="lg:w-2/3 w-full">
        <h2 class="font-header-5 font-bold mb-6 text-center lg:text-left">Stack &amp; toolbox</h2>
        <TechStack stacks={profile.stacks} />
      </div>
    </div>
  </section>

  <!-- Featured work -->
  <h2 id="section-featured" class="scroll-mt-20 sticky top-16 z-10 font-header-4 mx-auto w-full text-center bg-base-100/90 backdrop-blur py-3">
    Selected work
  </h2>
  {featured.map((project, i) => <ProjectSection project={project} index={i} />)}

  <!-- More projects -->
  {cards.length > 0 && (
    <section id="section-cards" class="w-full px-6 py-16 lg:py-20 bg-base-200/40">
      <div class="w-11/12 max-w-6xl mx-auto">
        <h3 class="font-header-5 font-bold mb-8 text-center">More projects</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {cards.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>
  )}

  <!-- Contact -->
  <h2 class="sticky top-16 z-10 font-header-4 mx-auto w-full text-center bg-base-100/90 backdrop-blur py-3">
    Get in touch
  </h2>
  <section id="section-contact" class="scroll-mt-24 w-full px-6 py-16">
    <Contact profile={profile} />
  </section>
</Base>

<script is:inline>
  (function () {
    const blocks = document.querySelectorAll('#content > section, #content article');
    if (!('IntersectionObserver' in window) || !blocks.length) return;
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    blocks.forEach((b) => { b.classList.add('reveal'); obs.observe(b); });
  })();
</script>
