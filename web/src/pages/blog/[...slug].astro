---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import PostMeta from '../../components/blog/PostMeta.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import { readingTime, isPublic } from '../../lib/blog';
import SubscribeForm from '../../components/SubscribeForm.astro';
import { jsonLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const posts = await getCollection('blog', isPublic);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTime(post.body ?? '');
const siteHref = (Astro.site?.href ?? 'https://bessavagner.com/').replace(/\/$/, '');
const personId = `${siteHref}/#vagner-bessa`;
const ogImage = `/blog/og/${post.id}.png`;
const modified = post.data.updatedDate ?? post.data.pubDate;

const blogPosting = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${Astro.url.href}#post`,
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: modified.toISOString(),
  author: { '@id': personId },
  publisher: { '@id': personId },
  inLanguage: 'en',
  keywords: post.data.tags.join(', '),
  image: new URL(ogImage, siteHref).href,
  mainEntityOfPage: Astro.url.href,
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: `${siteHref}/blog/` },
    { '@type': 'ListItem', position: 2, name: post.data.title, item: Astro.url.href },
  ],
};
---
<Base title={`${post.data.title} — Vagner Bessa`} description={post.data.description} ogImage={ogImage} ogType="article" spotlightGrid>
  <script is:inline type="application/ld+json" set:html={jsonLd(blogPosting)} />
  <script is:inline type="application/ld+json" set:html={jsonLd(breadcrumb)} />

  <article class="w-11/12 max-w-3xl mx-auto pt-28 pb-20">
    <a href="/blog/" class="inline-flex items-center gap-1 font-base text-sm text-primary hover:underline">← All posts</a>
    <header class="mt-6">
      <h1 class="font-header-4 font-bold leading-tight">{post.data.title}</h1>
      <PostMeta pubDate={post.data.pubDate} minutes={minutes} tags={post.data.tags} maxTags={post.data.tags.length} class="mt-4" />
    </header>
    {post.data.heroImage && (post.data.heroImageDark ? (
      <Fragment>
        <Image src={post.data.heroImage} alt={post.data.title} class="blog-hero-light rounded-2xl border border-primary/20 mt-8 w-full h-auto" />
        <Image src={post.data.heroImageDark} alt={post.data.title} class="blog-hero-dark rounded-2xl border border-primary/20 mt-8 w-full h-auto" />
      </Fragment>
    ) : (
      <Image src={post.data.heroImage} alt={post.data.title} class="rounded-2xl border border-primary/20 mt-8 w-full h-auto" />
    ))}
    {headings.length > 0 && <TableOfContents headings={headings} class="mt-8" />}
    <div class="prose prose-lg max-w-none mt-8">
      <Content />
    </div>
    <div class="mt-12 pt-8 border-t border-base-content/10">
      <a href="/#section-contact" class="btn btn-primary btn-sm font-base">Work with me →</a>
    </div>
    <SubscribeForm class="mt-10" />
  </article>
</Base>

<style>
  .blog-hero-dark { display: none; }
  :global([data-theme="custom-dark"]) .blog-hero-light { display: none; }
  :global([data-theme="custom-dark"]) .blog-hero-dark { display: block; }
</style>
