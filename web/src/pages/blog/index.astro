---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/blog/PostCard.astro';
import FeaturedPost from '../../components/blog/FeaturedPost.astro';
import { getPublishedPosts } from '../../lib/blog';

const posts = await getPublishedPosts();
const [featured, ...rest] = posts;
const siteHref = (Astro.site?.href ?? 'https://bessavagner.com/').replace(/\/$/, '');
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteHref}/blog/#blog`,
  name: 'Vagner Bessa — Blog',
  description: 'Articles on AI engineering, LLM agents, and building production software.',
  url: `${siteHref}/blog/`,
  author: { '@id': `${siteHref}/#vagner-bessa` },
  inLanguage: 'en',
};
---
<Base title="Blog — Vagner Bessa" description="Articles on AI engineering, LLM agents, and building production software in Python and TypeScript.">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  <section class="w-11/12 max-w-4xl mx-auto pt-28 pb-20">
    <h1 class="font-header text-4xl md:text-5xl font-semibold">Blog</h1>
    <p class="font-base text-lg text-base-content/70 mt-3">Notes on AI engineering, LLM agents, and shipping production software.</p>
    {posts.length === 0 ? (
      <p class="font-base text-base-content/60 mt-10">No posts yet, check back soon.</p>
    ) : (
      <div class="mt-12 space-y-12">
        <FeaturedPost post={featured} />
        {rest.length > 0 && (
          <div class="divide-y divide-base-content/10 border-t border-base-content/10">
            {rest.map((post) => <PostCard post={post} />)}
          </div>
        )}
      </div>
    )}
  </section>
</Base>
