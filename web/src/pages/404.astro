---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found — Vagner Bessa">
  <section class="min-h-[70vh] flex flex-col items-center justify-center text-center px-6">
    <p class="ubuntu-mono-regular text-accent tracking-widest">404</p>
    <h1 class="font-header-4 roboto-condensed-800 mt-2">Page not found</h1>
    <p class="font-base text-base-content/70 mt-4 max-w-md">
      The page you're looking for doesn't exist or has moved.
    </p>
    <a href="/" class="btn btn-primary font-base mt-8">Back home</a>
  </section>
</Base>
